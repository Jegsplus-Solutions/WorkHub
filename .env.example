# ─── Microsoft 365 / Entra ID ─────────────────────────────────────────────────
# Single-tenant App Registration in Entra ID
AZURE_TENANT_ID=f8cdef31-a31e-4b4a-93e4-5f571e91255a
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Entra group object IDs for role mapping
AZURE_GROUP_MANAGERS=group-object-id-for-managers
AZURE_GROUP_ADMINS=group-object-id-for-admins
AZURE_GROUP_EMPLOYEES=group-object-id-for-employees

# SharePoint site for payroll export
SHAREPOINT_SITE_ID=your-sharepoint-site-id
SHAREPOINT_DRIVE_ID=your-document-library-drive-id
SHAREPOINT_PAYROLL_FOLDER=Payroll/Exports

# ─── Supabase Auth (Microsoft SSO) ────────────────────────────────────────────
# These are set in Supabase Dashboard → Auth → Providers → Azure
# SUPABASE_AUTH_AZURE_CLIENT_ID (same as AZURE_CLIENT_ID)
# SUPABASE_AUTH_AZURE_SECRET (same as AZURE_CLIENT_SECRET)

# ─── App Settings ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-nlsd.netlify.app
NEXT_PUBLIC_APP_NAME=NLSD

# Graph sync webhook secret (Netlify function auth)
GRAPH_SYNC_SECRET=your-webhook-secret-32chars

# Default mileage rate (cents per km, overridable in settings)
DEFAULT_MILEAGE_RATE_PER_KM=0.61
